ABLY_API_KEY=           # Same Ably API key used by Locum1st
DATABASE_URL=           # Same PostgreSQL connection string used by Locum1st
BOT_USER_ID=bot-1stai   # Canonical 1stAi account seeded by Locum1st (do NOT run npm run setup — it mints a second, unrelated bot account)
OPENCLAW_BIN=/home/ubuntu/.npm-global/bin/openclaw
POLL_INTERVAL_MS=30000  # How often to check for new conversations (ms)
